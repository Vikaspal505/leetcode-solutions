class Solution {
    public int maximumElementAfterDecrementingAndRearranging(int[] arr) {
        Arrays.sort(arr);
        arr[0] = 1;
        int maxElement = 1;
        for (int i = 1; i < arr.length; ++i) {
            int excessDifference = Math.max(0, arr[i] - arr[i - 1] - 1);
            arr[i] -= excessDifference;
            maxElement = Math.max(maxElement, arr[i]);
        }
        return maxElement;
    }
}
